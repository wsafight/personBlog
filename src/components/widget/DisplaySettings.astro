<div id="display-setting" class="float-panel float-panel-closed absolute transition-all w-80 right-4 px-4 py-4" data-display-setting>
    <div class="flex flex-row gap-2 mb-3 items-center justify-between">
        <div class="flex gap-2 font-bold text-lg text-neutral-900 dark:text-neutral-100 transition relative ml-3
            before:w-1 before:h-4 before:rounded-md before:bg-[var(--primary)]
            before:absolute before:-left-3 before:top-[0.33rem]"
        >
            主题色
            <button aria-label="Reset to Default" class="btn-regular w-7 h-7 rounded-md active:scale-90" data-hue-reset>
                <div class="text-[var(--btn-content)]">
                    <svg xmlns="http://www.w3.org/2000/svg" width="0.875rem" height="0.875rem" viewBox="0 0 512 512"><path fill="currentColor" d="M125.7 160H176c17.7 0 32 14.3 32 32s-14.3 32-32 32H48c-17.7 0-32-14.3-32-32V64c0-17.7 14.3-32 32-32s32 14.3 32 32v51.2l17.6-17.6c87.5-87.5 229.3-87.5 316.8 0s87.5 229.3 0 316.8s-229.3 87.5-316.8 0c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0c62.5 62.5 163.8 62.5 226.3 0s62.5-163.8 0-226.3s-163.8-62.5-226.3 0z"/></svg>
                </div>
            </button>
        </div>
        <div class="flex gap-1">
            <div id="hueValue" class="transition bg-[var(--btn-regular-bg)] w-10 h-7 rounded-md flex justify-center
            font-bold text-sm items-center text-[var(--btn-content)]" data-hue-value>
                250
            </div>
        </div>
    </div>
    <div class="w-full h-6 px-1 bg-[oklch(0.80_0.10_0)] dark:bg-[oklch(0.70_0.10_0)] rounded select-none">
        <input aria-label="主题色" type="range" min="0" max="360"
               class="slider" id="colorSlider" step="5" style="width: 100%" data-hue-slider>
    </div>
</div>

<script>
import { getDefaultHue, getHue, setHue } from '@utils/setting-utils'

function initDisplaySettings() {
  document.querySelectorAll<HTMLElement>('[data-display-setting]').forEach(root => {
    if (root.dataset.bound === 'true') return
    root.dataset.bound = 'true'

    const slider = root.querySelector<HTMLInputElement>('[data-hue-slider]')
    const value = root.querySelector<HTMLElement>('[data-hue-value]')
    const reset = root.querySelector<HTMLButtonElement>('[data-hue-reset]')
    if (!slider || !value || !reset) return

    const defaultHue = getDefaultHue()
    const render = (hue: number) => {
      slider.value = String(hue)
      value.textContent = String(hue)
      reset.classList.toggle('opacity-0', hue === defaultHue)
      reset.classList.toggle('pointer-events-none', hue === defaultHue)
    }

    render(getHue())

    slider.addEventListener('input', () => {
      const hue = Number.parseInt(slider.value, 10)
      if (Number.isNaN(hue)) return
      setHue(hue)
      render(hue)
    })
    reset.addEventListener('click', () => {
      setHue(defaultHue)
      render(defaultHue)
    })
  })
}

initDisplaySettings()
document.addEventListener('astro:page-load', initDisplaySettings)
</script>

<style>
#display-setting input[type="range"] {
  -webkit-appearance: none;
  height: 1.5rem;
  background-image: var(--color-selection-bar);
  transition: background-image 0.15s ease-in-out;
}

#display-setting input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 0.5rem;
  height: 1rem;
  border-radius: 0.125rem;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: none;
}

#display-setting input[type="range"]::-webkit-slider-thumb:hover {
  background: rgba(255, 255, 255, 0.8);
}

#display-setting input[type="range"]::-webkit-slider-thumb:active {
  background: rgba(255, 255, 255, 0.6);
}

#display-setting input[type="range"]::-moz-range-thumb {
  -webkit-appearance: none;
  width: 0.5rem;
  height: 1rem;
  border-width: 0;
  border-radius: 0.125rem;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: none;
}

#display-setting input[type="range"]::-moz-range-thumb:hover {
  background: rgba(255, 255, 255, 0.8);
}

#display-setting input[type="range"]::-moz-range-thumb:active {
  background: rgba(255, 255, 255, 0.6);
}

#display-setting input[type="range"]::-ms-thumb {
  -webkit-appearance: none;
  width: 0.5rem;
  height: 1rem;
  border-radius: 0.125rem;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: none;
}

#display-setting input[type="range"]::-ms-thumb:hover {
  background: rgba(255, 255, 255, 0.8);
}

#display-setting input[type="range"]::-ms-thumb:active {
  background: rgba(255, 255, 255, 0.6);
}
</style>
