---
import codeFontStylesheetUrl from '@fontsource-variable/jetbrains-mono/wght.css?url'
import CodeCopyScript from './CodeCopyScript.astro'

interface Props {
  class: string
  enableCodeFeatures?: boolean
}
const className = Astro.props.class
const enableCodeFeatures = Astro.props.enableCodeFeatures ?? false
---
{enableCodeFeatures && <link rel="stylesheet" href={codeFontStylesheetUrl} />}
<div data-pagefind-body class=`prose dark:prose-invert prose-base !max-w-none custom-md ${className}`>
    <slot/>
</div>
{enableCodeFeatures && <CodeCopyScript />}
